{
	"name": "monithor-mqtt",
	"private": true,
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"scripts": {
		"dev:api": "bun --filter elysia-mqtt dev",
		"dev:web": "bun --filter nextjs-mqtt dev",
		"dev": "bun run --parallel --filter '*' dev"
	},
	"devDependencies": {
		"@types/bun": "^1.3.9"
	},
	"dependencies": {
		"@elysiajs/cors": "^1.4.1",
		"mqtt": "^5.15.0"
	}
}